{
  "version": 2,
  "builds": [
    {
      "src": "portfolio_project/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 90,
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "portfolio_project/wsgi.py"
    }
  ]
}
